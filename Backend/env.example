# SecureScan Backend — variables d'environnement
# Copier en .env et adapter : cp env.example .env

# Base de données PostgreSQL (aligné sur securescanbdd.sql)
DATABASE_URL=postgresql://user:password@localhost:5432/securescan

# Optionnel
DEBUG=false
PROJECT_NAME=SecureScan
VERSION=0.1.0

# CORS (origines autorisées pour le frontend)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Répertoire de travail (clonage / uploads)
WORKSPACE_DIR=./workspace
